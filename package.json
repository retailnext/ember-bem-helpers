{
  "repository": {
    "type": "git",
    "url": "git+https://github.com/retailnext/ember-bem-helpers.git"
  },
  "license": "MIT",
  "author": "RetailNext",
  "scripts": {
    "build": "pnpm --filter ember-bem-helpers build",
    "lint": "pnpm --filter '*' lint",
    "prepare": "pnpm build",
    "start": "concurrently 'npm:start:*' --restart-after 5000 --prefix-colors cyan,white,yellow",
    "start:addon": "pnpm --filter ember-bem-helpers start --no-watch.clearScreen",
    "start:test-app": "pnpm --filter test-app start",
    "test": "pnpm --filter '*' test",
    "test:ember": "pnpm --filter '*' test:ember"
  },
  "engines": {
    "node": ">= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config"
  },
  "bugs": {
    "url": "https://github.com/retailnext/ember-bem-helpers/issues"
  },
  "pnpm": {
    "overrides": {
      "ansi-html": "0.0.9",
      "babel-plugin-module-resolver": "5.0.3",
      "cookie": "1.1.1",
      "package-json": "10.0.1",
      "tmp": ">=0.2.4",
      "diff@<8.0.3": ">=8.0.3",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "@babel/runtime@<7.26.10": ">=7.26.10"
    }
  },
  "homepage": "https://github.com/retailnext/ember-bem-helpers#readme",
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
